{
	"compilerOptions": {
		"target": "esnext",
		"jsx": "react-jsx",
		"module": "esnext",
		"rootDir": ".",
		"moduleResolution": "bundler",
		"baseUrl": "./src",
		"paths": {
			"@base-components/*": ["components/ui/base/*"],
			"@components/*": ["components/ui/8bit/*"],
			"@lib/*": ["lib/*"],
			"@actors/*": ["actors/*"],
			"@classes/*": ["classes/*"],
			"@maps/*": ["maps/*"],
			"@constants": ["constants.ts"],
			"@resources": ["resources.ts"],
			"@character-animations": ["character-animations.ts"],
			"@helpers": ["helpers.ts"],
			"@MainGameScene": ["MainGameScene.ts"]
		},
		"outDir": "dist",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true
	}
}
